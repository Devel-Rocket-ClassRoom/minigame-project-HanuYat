# Force LF line endings for all text files regardless of OS.
# Overrides per-user core.autocrlf settings.

* text=auto eol=lf

# Source code
*.cs text eol=lf
*.csx text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf

# Unity assets — binary marking prevents Git from line-end-normalizing
# binary-format scene/asset files (which would corrupt them).
# Unity itself handles its own LF/CRLF for text YAML serialization.
*.unity binary
*.asset binary
*.mat binary
*.prefab binary
*.meta binary
*.controller binary
*.anim binary
*.physicMaterial binary
*.physicsMaterial2D binary
*.playable binary
*.mixer binary
*.shadergraph binary
*.shadersubgraph binary
*.preset binary
*.lighting binary
*.guiskin binary
*.fontsettings binary
*.flare binary
*.terrainlayer binary
*.signal binary
*.mask binary
*.brush binary

# Config / docs / data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.inputactions text eol=lf
.csharpierrc text eol=lf

# Scripts
*.ps1 text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Binary assets (do not touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tiff binary
*.tif binary
*.exr binary
*.hdr binary
*.psd binary
*.ico binary
*.fbx binary
*.obj binary
*.blend binary
*.glb binary
*.gltf binary
*.dae binary
*.3ds binary
*.max binary
*.maya binary
*.wav binary
*.mp3 binary
*.ogg binary
*.aif binary
*.aiff binary
*.mp4 binary
*.mov binary
*.webm binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.unitypackage binary
*.dll binary
